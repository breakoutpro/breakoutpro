# Breakout Pro - Environment Variables (EXAMPLE - placeholders only, never commit real .env)

# ---- CLIENT-SIDE (VITE_ prefix = SHIPPED to browser bundle). Only publishable/non-secret values here. ----
# Groq AI key (client AI features). Lower risk; rotate if abused.
VITE_GROQ_KEY=your_groq_key_here
# Razorpay PUBLISHABLE key (safe for frontend by design - never the secret key).
VITE_RAZORPAY_KEY=your_razorpay_publishable_key_here

# ---- SERVER-ONLY (NO VITE_ prefix = never shipped to browser). Set these in Vercel. ----
# Admin login - compared inside api/auth.js on the server only.
ADMIN_PHONE=your_admin_phone
ADMIN_PASS=your_new_strong_admin_password
# Private beta invite codes (comma-separated) - validated server-side in api/auth.js.
BETA_CODES=BETA2026,EARLY50,TRADER100
# Secret used to sign session tokens (any long random string).
SESSION_SECRET=your_long_random_session_secret
