# Breakout Pro - Environment Variables (EXAMPLE - placeholders only, never commit real .env)

# ============================================================
# SERVER-ONLY SECRETS (NO VITE_ prefix - never shipped to browser)
# Set these in Vercel -> Settings -> Environment Variables.
# ============================================================
ADMIN_PHONE=
ADMIN_PASS=
BETA_CODES=
SESSION_SECRET=
GROQ_API_KEY=

# ============================================================
# CLIENT-SIDE PUBLISHABLE KEYS (VITE_ prefix = shipped to browser)
# Only genuinely public/publishable values belong here.
# ============================================================
# Razorpay PUBLISHABLE key (safe for frontend by design - never the secret key)
VITE_RAZORPAY_KEY=
