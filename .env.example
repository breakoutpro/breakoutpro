# Breakout Pro - Environment Variables (EXAMPLE - use placeholders only)
# Copy this file to .env and fill with real values. NEVER commit .env to git.

# AI features (optional - features show "unavailable" state if empty)
VITE_GROQ_KEY=your_groq_api_key_here

# Admin login (private beta owner access)
VITE_ADMIN_PHONE=your_admin_phone_here
VITE_ADMIN_PASS=your_strong_admin_password_here

# Private beta invite codes (comma-separated, e.g. BETA2026,EARLY100,TRADER50)
VITE_BETA_CODES=CODE1,CODE2,CODE3
